<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="16dp"
    tools:context=".HomeActivity">

    <!-- Header con título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧠 Trivia Cultural"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnLogout"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_logout"
            android:contentDescription="Cerrar sesión"
            app:tint="@color/white" />

    </LinearLayout>

    <!-- Sección TOP 3 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏆 TOP 3 MEJORES"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Container del podio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Segundo lugar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/podium_second"
            android:padding="12dp">

            <TextView
                android:text="🥈"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvSecondName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carlos R."
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvSecondScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2,650"
                android:textSize="14sp"
                android:textColor="#FFD700"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Primer lugar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/podium_first"
            android:padding="16dp"
            android:layout_marginTop="-20dp">

            <TextView
                android:text="👑"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvFirstName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="María G."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvFirstScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2,847"
                android:textSize="16sp"
                android:textColor="#FFD700"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Tercer lugar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/podium_third"
            android:padding="12dp">

            <TextView
                android:text="🥉"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvThirdName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana M."
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvThirdScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2,430"
                android:textSize="14sp"
                android:textColor="#FFD700"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Título del ranking -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 RANKING GENERAL"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Lista del ranking -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRanking"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/ranking_background"
        android:padding="8dp"
        tools:listitem="@layout/item_ranking" />

    <!-- Botón de jugar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎮 ¡JUGAR AHORA!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/play_button_color"
        app:icon="@drawable/ic_play"
        app:iconGravity="textStart"
        app:iconSize="24dp" />

</LinearLayout>